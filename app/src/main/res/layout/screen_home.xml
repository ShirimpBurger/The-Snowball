<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_home"
    android:orientation="horizontal">

    <!-- Side Navigation -->
    <LinearLayout
        android:layout_width="48dp"
        android:layout_height="match_parent"
        android:gravity="top|center_horizontal"
        android:orientation="vertical"
        android:paddingTop="40dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_home"
            android:tint="#2563EB" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:padding="8dp"
            android:src="@drawable/ic_history"
            android:tint="#9CA3AF" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:padding="8dp"
            android:src="@drawable/ic_partner"
            android:tint="#9CA3AF" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:padding="8dp"
            android:src="@drawable/ic_settings"
            android:tint="#9CA3AF" />

    </LinearLayout>

    <!-- Main Content -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingHorizontal="20dp">

            <!-- Header Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="80dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="올해 정말 잘하고 있어요 ✨"
                    android:textColor="#6B7280"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-bold"
                    android:text="5,000,000원"
                    android:textColor="#111827"
                    android:textSize="32sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="12월 저축 현황"
                    android:textColor="#9CA3AF"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Stats Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_card_glass"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="📈 지난달보다 +50만원"
                    android:textColor="#1F2937"
                    android:textSize="15sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="꾸준히 눈덩이를 굴리고 있어요"
                    android:textColor="#6B7280"
                    android:textSize="13sp" />

            </LinearLayout>

            <!-- Penguin Image -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/penguin"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/penguin_sprite_frame6" />

            </FrameLayout>

            <!-- Record Button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="40dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↓ 기록하기"
                    android:textColor="#9CA3AF"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="4dp"
                    android:src="@drawable/ic_expand_more"
                    android:tint="#9CA3AF" />

            </LinearLayout>

        </LinearLayout>

        <!-- Page Indicator -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="6dp"
            android:orientation="vertical">

            <View
                android:layout_width="4dp"
                android:layout_height="16dp"
                android:background="@drawable/indicator_active" />

            <View
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/indicator_inactive" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
