<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_home"
    android:orientation="vertical">

    <!-- Header with Back Button -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start|center_vertical"
            android:background="@drawable/bg_circle_hover"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_back"
            android:tint="#4B5563" />

    </FrameLayout>

    <!-- Main Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp">

        <!-- Penguin Image -->
        <ImageView
            android:id="@+id/ivPenguins"
            android:layout_width="256dp"
            android:layout_height="192dp"
            android:layout_marginTop="24dp"
            android:scaleType="fitCenter"
            tools:background="#E5E7EB" />

        <!-- Title Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:fontFamily="sans-serif-medium"
            android:text="파트너 초대"
            android:textColor="#111827"
            android:textSize="24sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="아래 코드를 파트너에게 공유해주세요"
            android:textColor="#6B7280"
            android:textSize="16sp" />

        <!-- My Code Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:background="@drawable/bg_code_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:id="@+id/tvMyCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:text="SNOW-8291"
                android:textColor="#111827"
                android:textSize="32sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/btnCopyCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_copy_button"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_copy"
                    android:tint="#6B7280" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="코드 복사"
                    android:textColor="#6B7280"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Partner Code Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="12dp"
                android:text="파트너 코드"
                android:textColor="#4B5563"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/etPartnerCode"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@drawable/bg_partner_input"
                android:hint="코드를 입력해주세요"
                android:inputType="text"
                android:paddingHorizontal="24dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:textSize="18sp" />

        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Connect Button -->
        <TextView
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="40dp"
            android:background="@drawable/bg_connect_button"
            android:fontFamily="sans-serif-bold"
            android:gravity="center"
            android:text="연결하기"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

    </LinearLayout>

</LinearLayout>
