<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    android:orientation="horizontal">

    <!-- Side Navigation -->
    <LinearLayout
        android:layout_width="48dp"
        android:layout_height="match_parent"
        android:gravity="top|center_horizontal"
        android:orientation="vertical"
        android:paddingTop="40dp">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_home"
            android:tint="#94A3B8" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:padding="8dp"
            android:src="@drawable/ic_history"
            android:tint="#94A3B8" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:padding="8dp"
            android:src="@drawable/ic_favorite"
            android:tint="#94A3B8" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginBottom="32dp"
            android:padding="8dp"
            android:src="@drawable/ic_settings"
            android:tint="#94A3B8" />

    </LinearLayout>

    <!-- Main Content -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="@drawable/bg_gradient_home">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Drag Handle -->
            <View
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_drag_handle" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:fillViewport="true"
                android:paddingBottom="120dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="16dp">

                    <!-- Summary Card -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_glass"
                        android:orientation="vertical"
                        android:padding="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12월 자산 기록"
                            android:textColor="#475569"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:fontFamily="sans-serif-bold"
                            android:text="₩5,000,000"
                            android:textColor="#0F172A"
                            android:textSize="32sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="지난달보다 +500,000 📈"
                            android:textColor="#2b8cee"
                            android:textSize="14sp" />

                        <!-- Progress Indicator -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="24dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="horizontal">

                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:layout_marginEnd="8dp"
                                    android:background="@drawable/circle_primary" />

                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:layout_marginEnd="8dp"
                                    android:background="@drawable/circle_primary" />

                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:layout_marginEnd="8dp"
                                    android:background="@drawable/circle_primary" />

                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:layout_marginEnd="8dp"
                                    android:background="@drawable/circle_primary" />

                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:background="@drawable/circle_gray" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4/5 입력 완료"
                                android:textColor="#94A3B8"
                                android:textSize="12sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Input Fields -->
                    <!-- 부동산 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginBottom="8dp"
                            android:text="부동산"
                            android:textColor="#475569"
                            android:textSize="13sp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_input_field">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_marginStart="16dp"
                                android:text="₩"
                                android:textColor="#94A3B8"
                                android:textSize="16sp" />

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="end|center_vertical"
                                android:inputType="numberDecimal"
                                android:paddingHorizontal="16dp"
                                android:text="3,500,000"
                                android:textColor="#0F172A"
                                android:textSize="18sp" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginTop="8dp"
                            android:text="지난달 ₩3,500,000 · 탭하여 복사"
                            android:textColor="#94A3B8"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- 예적금 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginBottom="8dp"
                            android:text="예적금"
                            android:textColor="#475569"
                            android:textSize="13sp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_input_field">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_marginStart="16dp"
                                android:text="₩"
                                android:textColor="#94A3B8"
                                android:textSize="16sp" />

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="end|center_vertical"
                                android:inputType="numberDecimal"
                                android:paddingHorizontal="16dp"
                                android:text="1,000,000"
                                android:textColor="#0F172A"
                                android:textSize="18sp" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginTop="8dp"
                            android:text="지난달 ₩800,000 · 탭하여 복사"
                            android:textColor="#94A3B8"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- 현금 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginBottom="8dp"
                            android:text="현금"
                            android:textColor="#475569"
                            android:textSize="13sp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_input_field">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_marginStart="16dp"
                                android:text="₩"
                                android:textColor="#94A3B8"
                                android:textSize="16sp" />

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="end|center_vertical"
                                android:inputType="numberDecimal"
                                android:paddingHorizontal="16dp"
                                android:text="200,000"
                                android:textColor="#0F172A"
                                android:textSize="18sp" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginTop="8dp"
                            android:text="지난달 ₩300,000 · 탭하여 복사"
                            android:textColor="#94A3B8"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- 연금 + ISA -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginBottom="8dp"
                            android:text="연금 + ISA"
                            android:textColor="#475569"
                            android:textSize="13sp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_input_field">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_marginStart="16dp"
                                android:text="₩"
                                android:textColor="#94A3B8"
                                android:textSize="16sp" />

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="end|center_vertical"
                                android:inputType="numberDecimal"
                                android:paddingHorizontal="16dp"
                                android:text="300,000"
                                android:textColor="#0F172A"
                                android:textSize="18sp" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginTop="8dp"
                            android:text="지난달 ₩250,000 · 탭하여 복사"
                            android:textColor="#94A3B8"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- 재테크 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginBottom="8dp"
                            android:text="재테크"
                            android:textColor="#475569"
                            android:textSize="13sp" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:background="@drawable/bg_input_field">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_marginStart="16dp"
                                android:text="₩"
                                android:textColor="#94A3B8"
                                android:textSize="16sp" />

                            <EditText
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@null"
                                android:fontFamily="sans-serif-medium"
                                android:gravity="end|center_vertical"
                                android:hint="0"
                                android:inputType="numberDecimal"
                                android:paddingHorizontal="16dp"
                                android:textColor="#0F172A"
                                android:textColorHint="#CBD5E1"
                                android:textSize="18sp" />

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center_vertical|end"
                                android:layout_marginEnd="48dp"
                                android:src="@drawable/ic_expand_more"
                                android:tint="#94A3B8" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginTop="8dp"
                            android:text="지난달 ₩0 · 탭하여 복사"
                            android:textColor="#94A3B8"
                            android:textSize="12sp" />

                    </LinearLayout>

                </LinearLayout>

            </ScrollView>

        </LinearLayout>

        <!-- Bottom Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_bottom_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            android:paddingVertical="16dp">

            <!-- Partner Button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_partner_button">

                    <ImageView
                        android:id="@+id/ivPartnerPenguin"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:scaleType="fitCenter"
                        tools:background="#E5E7EB" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="파트너 기록"
                    android:textColor="#94A3B8"
                    android:textSize="11sp" />

            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Save Button -->
            <TextView
                android:id="@+id/btnSave"
                android:layout_width="140dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_primary_button"
                android:fontFamily="sans-serif-bold"
                android:gravity="center"
                android:text="저장하기"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Page Indicator -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="6dp"
            android:orientation="vertical">

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:background="@drawable/circle_gray" />

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/circle_gray_dark" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout>
